{
  "name": "api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "cd ../.. && drizzle-kit generate --config drizzle.config.json",
    "db:migrate": "cd ../.. && drizzle-kit migrate --config drizzle.config.json",
    "db:seed": "tsx src/scripts.ts seed",
    "db:reset-seed": "tsx src/scripts.ts reset-seed",
    "db:fresh-reset": "tsx src/scripts.ts fresh-reset"
  },
  "dependencies": {
    "@good-intent/shared": "file:../../packages/shared",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "nanoid": "^5.1.5",
    "supertest": "^7.2.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
